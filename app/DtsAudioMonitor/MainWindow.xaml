<Window x:Class="DtsAudioMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DTS Audio Monitor"
        Width="420" Height="520"
        MinWidth="380" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        ResizeMode="CanMinimize"
        ShowInTaskbar="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="DTS Audio Monitor" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="Фоновый контроль пространственного звука" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" />
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="12" Padding="10,4" Background="#222633">
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
            </Border>
        </Grid>

        <!-- Device card -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Сейчас воспроизведение" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                <TextBlock Text="{Binding DeviceName}" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                           TextWrapping="Wrap" Margin="0,6,0,0" />
                <TextBlock Text="{Binding DeviceKindLabel}" FontSize="12" Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- Auto toggle -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1" CornerRadius="14" Padding="14,12" Margin="0,0,0,12">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Автоматический режим" FontSize="14" Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="Следит за устройством в фоне" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
                </StackPanel>
                <CheckBox IsChecked="{Binding AutoEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center"
                          Style="{StaticResource ToggleSwitchStyle}" />
            </Grid>
        </Border>

        <!-- Fix button -->
        <Button Grid.Row="3" Content="Применить DTS для монитора" Command="{Binding FixCommand}"
                IsEnabled="{Binding CanFix}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,12" />

        <!-- Log -->
        <Border Grid.Row="4" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1" CornerRadius="14" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Журнал" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8" />
                <ListBox ItemsSource="{Binding LogLines}" Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource MutedBrush}" FontSize="11" FontFamily="Consolas"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
            </DockPanel>
        </Border>

        <!-- Startup -->
        <CheckBox Grid.Row="5" Content="Запускать с Windows" IsChecked="{Binding StartWithWindows}"
                  Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0" FontSize="12" />
    </Grid>
</Window>
