<Window x:Class="DtsAudioMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DTS Audio Monitor"
        Width="440" Height="580"
        MinWidth="400" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        ResizeMode="CanMinimize"
        ShowInTaskbar="True"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Background>
        <StaticResource ResourceKey="WindowBgGradientBrush" />
    </Window.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Hero header -->
        <Border Grid.Row="0" CornerRadius="0,0,24,24" Padding="24,22,24,28" Margin="0,0,0,-8">
            <Border.Background>
                <StaticResource ResourceKey="HeroGradientBrush" />
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#5E4FD9" BlurRadius="28" ShadowDepth="4" Opacity="0.35" Direction="270" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="56" Height="56" CornerRadius="16" Background="#30FFFFFF" Margin="0,0,16,0">
                    <Grid>
                        <Image x:Name="HeroLogoImage" Width="44" Height="44"
                               RenderOptions.BitmapScalingMode="HighQuality" Visibility="Collapsed" />
                        <TextBlock x:Name="HeroLogoFallback" Text="&#xE7F6;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="DTS Audio Monitor" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Пространственный звук в фоне" FontSize="12" Foreground="#E8E4FF" Opacity="0.9" Margin="0,3,0,0" />
                    <TextBlock Text="{Binding VersionLabel}" FontSize="10" Foreground="#D4CCFF" Opacity="0.75" Margin="0,6,0,0" />
                </StackPanel>

                <Border Grid.Column="2" VerticalAlignment="Top" CornerRadius="20" Padding="12,6" Background="#25FFFFFF">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
            <StackPanel>

                <!-- Device -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="DeviceIconBg" Width="44" Height="44" CornerRadius="12" Background="#252B3A" Margin="0,0,14,0">
                            <TextBlock x:Name="DeviceIconText" Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Сейчас воспроизведение" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding DeviceName}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap" Margin="0,5,0,0" LineHeight="20" />
                            <TextBlock x:Name="DeviceKindLabel" Text="{Binding DeviceKindLabel}" FontSize="12" FontWeight="Medium"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Auto -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12" Padding="14,14">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Автоматический режим" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Text="Следит за устройством в фоне" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox IsChecked="{Binding AutoEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Style="{StaticResource ToggleSwitchStyle}" />
                    </Grid>
                </Border>

                <Button Content="Применить DTS для монитора" Command="{Binding FixCommand}"
                        IsEnabled="{Binding CanFix}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,14"
                        FontFamily="Segoe UI Variable Display, Segoe UI" />

                <!-- Log -->
                <Border Style="{StaticResource CardBorderStyle}" Padding="14" MinHeight="140">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Журнал" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10" />
                        <ListBox ItemsSource="{Binding LogLines}" Style="{StaticResource LogListStyle}"
                                 ItemContainerStyle="{StaticResource LogItemStyle}" MaxHeight="120" />
                    </DockPanel>
                </Border>

                <CheckBox Content="Запускать с Windows" IsChecked="{Binding StartWithWindows}"
                          Style="{StaticResource FooterCheckStyle}" Margin="4,14,0,4" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
