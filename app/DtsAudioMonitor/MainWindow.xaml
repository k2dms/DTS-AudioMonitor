<Window x:Class="DtsAudioMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DTS Audio Monitor"
        Width="448" Height="632"
        MinWidth="408" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        ResizeMode="CanMinimize"
        ShowInTaskbar="True"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Border x:Name="RootChrome" CornerRadius="16" ClipToBounds="True"
            RenderTransformOrigin="0.5,0.5"
            BorderBrush="#35FFFFFF" BorderThickness="1">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="0" Opacity="0.55" />
        </Border.Effect>
        <Grid>
            <Grid.Background>
                <StaticResource ResourceKey="WindowBgGradientBrush" />
            </Grid.Background>

            <Ellipse Width="320" Height="220" HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-80,-60,0,0" Fill="{StaticResource AmbientGlowBrush}" IsHitTestVisible="False" />
            <Ellipse Width="200" Height="180" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-40,40" Opacity="0.35" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.7,0.5" Center="0.7,0.5" RadiusX="0.8" RadiusY="0.8">
                        <GradientStop Color="#305E4FD9" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Hero + custom title bar -->
                <Border Grid.Row="0" CornerRadius="16,16,28,28" Padding="0,0,0,20" Margin="0,0,0,-8">
                    <Border.Background>
                        <StaticResource ResourceKey="HeroGradientBrush" />
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#5E4FD9" BlurRadius="24" ShadowDepth="3" Opacity="0.4" Direction="270" />
                    </Border.Effect>
                    <Grid>
                        <Border Background="{StaticResource HeroOverlayBrush}" CornerRadius="16,16,28,28" IsHitTestVisible="False" />
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0" Opacity="0.85">
                                    <Ellipse Width="6" Height="6" Fill="#FF6B8AFF" Margin="0,0,6,0" />
                                    <TextBlock Text="DTS Audio Monitor" FontSize="11" Foreground="#E0DAFF" FontWeight="Medium" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,4,8,0">
                                    <Button Style="{StaticResource ChromeButtonStyle}" Content="&#xE921;"
                                            ToolTip="Свернуть" Click="Minimize_Click" />
                                    <Button Style="{StaticResource ChromeCloseButtonStyle}" Content="&#xE8BB;"
                                            ToolTip="Скрыть в трей" Click="HideToTray_Click" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="22,0,22,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Width="58" Height="58" CornerRadius="18" Margin="0,0,16,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#45FFFFFF" Offset="0" />
                                            <GradientStop Color="#18FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="18">
                                        <Grid>
                                            <Image x:Name="HeroLogoImage" Width="46" Height="46"
                                                   RenderOptions.BitmapScalingMode="HighQuality" Visibility="Collapsed" />
                                            <TextBlock x:Name="HeroLogoFallback" Text="&#xE7F6;" FontFamily="Segoe MDL2 Assets" FontSize="27"
                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="DTS Audio Monitor" FontSize="21" FontWeight="SemiBold" Foreground="White" />
                                    <TextBlock Text="Пространственный звук в фоне" FontSize="12" Foreground="#F0ECFF" Opacity="0.88" Margin="0,4,0,0" />
                                    <Border Background="#22FFFFFF" CornerRadius="8" Padding="8,3" HorizontalAlignment="Left" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding VersionLabel}" FontSize="10" Foreground="#E8E2FF" FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>

                                <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="20" Padding="12,7"
                                        Background="#28FFFFFF" BorderBrush="#35FFFFFF" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Body (no outer scrollbar at default size) -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="20,12,20,8">
                    <StackPanel>

                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="DeviceIconBg" Width="46" Height="46" CornerRadius="14" Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2A3145" Offset="0" />
                                            <GradientStop Color="#1A2030" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock x:Name="DeviceIconText" Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="21"
                                               Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Сейчас воспроизведение" FontSize="11" Foreground="{StaticResource MutedBrush}" FontWeight="Medium" />
                                    <TextBlock Text="{Binding DeviceName}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                               TextWrapping="Wrap" Margin="0,6,0,0" LineHeight="21" />
                                    <TextBlock x:Name="DeviceKindLabel" Text="{Binding DeviceKindLabel}" FontSize="12" FontWeight="SemiBold"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10" Padding="16,14">
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Автоматический режим" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="Следит за устройством в фоне" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                                <CheckBox IsChecked="{Binding AutoEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Style="{StaticResource ToggleSwitchStyle}" />
                            </Grid>
                        </Border>

                        <Button Content="Применить DTS для монитора" Command="{Binding FixCommand}"
                                IsEnabled="{Binding CanFix}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,10" />

                        <Border Style="{StaticResource CardBorderStyle}" Padding="14">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <TextBlock Text="Журнал" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" />
                                    <Border HorizontalAlignment="Right" Background="#141820" CornerRadius="6" Padding="8,2">
                                        <TextBlock Text="live" FontSize="9" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" />
                                    </Border>
                                </Grid>
                                <Border Background="#0D1018" CornerRadius="12" Padding="10,8" BorderBrush="#222838" BorderThickness="1">
                                    <ListBox ItemsSource="{Binding LogLines}" Style="{StaticResource LogListStyle}"
                                             ItemContainerStyle="{StaticResource LogItemStyle}" MaxHeight="108" />
                                </Border>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer always visible -->
                <Border Grid.Row="2" Padding="20,10,20,16" BorderBrush="#1E2433" BorderThickness="0,1,0,0">
                    <CheckBox Content="Запускать с Windows" IsChecked="{Binding StartWithWindows}"
                              Style="{StaticResource FooterCheckStyle}" HorizontalAlignment="Center" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
